{
  "name": "strange-properties",
  "version": "1.0.0",
  "description": "Enhances Obsidian's property panel with value-based CSS targeting, class injection, section headers, and empty-property filtering.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint:css": "stylelint styles.css",
    "lint:css:fix": "stylelint styles.css --fix"
  },
  "devDependencies": {
    "@types/node": "^16.11.6",
    "@types/sortablejs": "^1.15.9",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.17.3",
    "obsidian": "github:obsidianmd/obsidian-api",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  },
  "dependencies": {
    "sortablejs": "^1.15.7"
  }
}
